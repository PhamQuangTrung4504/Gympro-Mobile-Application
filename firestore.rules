rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Thay đổi hàm check: Chấp nhận request từ ứng dụng Flutter sử dụng Cognito
    function isCognitoUser() {
      return true; 
    }
    
    // Users collection
    match /users/{userId} {
      allow create, read, update, delete: if true;
    }
    
    // Trainers collection
    match /trainers/{trainerId} {
      allow read, create, update, delete: if true;
    }
    
    // Trainer Rentals collection
    match /trainer_rentals/{rentalId} {
      allow read, create, update, delete: if true;
    }
    
    // Membership Cards collection (camelCase)
    match /membershipCards/{membershipId} {
      allow read, create, update, delete: if true;
    }
    
    // Membership Cards collection (snake_case)
    match /membership_cards/{membershipId} {
      allow read, create, update, delete: if true;
    }
    
    // User Memberships collection
    match /user_memberships/{userMembershipId} {
      allow read, create, update, delete: if true;
    }
    
    // Membership Purchases collection
    match /membership_purchases/{purchaseId} {
      allow read, create, update, delete: if true;
    }
    
    // Trainer Assignments collection
    match /trainer_assignments/{assignmentId} {
      allow read, create, update, delete: if true;
    }
    
    // Trainer Reviews collection
    match /trainer_reviews/{reviewId} {
      allow read, create, update, delete: if true;
    }
    
    // Check-ins collection
    match /check_ins/{checkInId} {
      allow read, create, update, delete: if true;
    }
    
    // News collection
    match /news/{newsId} {
      allow read, create, update, delete: if true;
    }
    
    // Workout Schedules collection
    match /workout_schedules/{scheduleId} {
      allow read, create, update, delete: if true;
    }
    
    // Exercises collection
    match /exercises/{exerciseId} {
      allow read, create, update, delete: if true;
    }
    
    // User Schedules collection
    match /user_schedules/{scheduleId} {
      allow read, create, update, delete: if true;
    }
    
    // Comments collection
    match /comments/{commentId} {
      allow read, create, update, delete: if true;
    }
    
    // Payment Transactions collection
    match /payment_transactions/{transactionId} {
      allow read, create, update, delete: if true;
    }
    
    // User News Interactions collection
    match /user_news_interactions/{interactionId} {
      allow read, create, update, delete: if true;
    }
    
    // Products collection
    match /products/{productId} {
      allow read, create, update, delete: if true;
    }
    
    // Shopping Carts collection
    match /carts/{cartId} {
      allow read, write: if true;
    }
    
    // Orders collection
    match /orders/{orderId} {
      allow read, create, update, delete: if true;
    }
    
    // Shipping Addresses collection
    match /shipping_addresses/{addressId} {
      allow read, create, update, delete: if true;
    }
    
    // Khóa các collection lạ khác không được định nghĩa
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
